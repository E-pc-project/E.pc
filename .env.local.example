# ───────────────────────────────────────────────────────────────
#  E.PC — DATABASE (Turso / libSQL)
# ───────────────────────────────────────────────────────────────
#  ЛОКАЛ дээр эдгээрийг ХООСОН орхивол апп node_modules/.epc-data доtorх
#  SQLite файлыг ашиглана (юу ч тохируулах шаардлагагүй).
#
#  VERCEL дээр (заавал):
#   1. https://turso.tech  → бүртгүүл, database үүсгэ
#   2. Database URL + auth token-оо ав (turso db show / turso db tokens create)
#   3. Vercel → Project → Settings → Environment Variables дотор доорхийг оруул:
#
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# ───────────────────────────────────────────────────────────────
#  E.PC — имэйл дамжуулах тохиргоо  (заавал биш, гэхдээ санал болгоё)
# ───────────────────────────────────────────────────────────────
#  Хэрэглэгчийн бүртгүүлсэн gaming төвийн мэдээлэл доорх хаягруу
#  автоматаар имэйлээр илгээгдэнэ.
#
#  Gmail дээр ажиллуулахын тулд:
#   1. e.pc.project001@gmail.com хаягтаа 2-Step Verification асаа
#   2. https://myaccount.google.com/apppasswords  → App Password үүсгэ
#   3. Гарсан 16 оронтой кодыг SMTP_PASS дотор тавь
#
#  Энэ файлыг хуулж нэрийг нь  ".env.local"  болгож хадгал.
#  (Тохируулаагүй бол апп ажиллана, мэдээлэл DB-д хадгалагдана, имэйл л явахгүй.)
# ───────────────────────────────────────────────────────────────

MAIL_TO=e.pc.project001@gmail.com
MAIL_FROM="E.PC Platform <e.pc.project001@gmail.com>"

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=e.pc.project001@gmail.com
SMTP_PASS=your-16-char-app-password
